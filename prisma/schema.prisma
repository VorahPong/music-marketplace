generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String?
  handle       String    @unique
  email        String    @unique
  passwordHash String
  points       Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tracks       Track[]
  sessions     Session[]
  comments     Comment[]
  likes        Like[]
  purchases TrackPurchase[]
}

model Track {
  id            String    @id @default(cuid())
  title         String
  description   String?
  fileUrl       String
  fileType      String
  trackType     TrackType @default(SONG)
  isForSale     Boolean   @default(false)
  priceInPoints Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownerId       String?
  owner         User?     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  comments      Comment[]
  likes         Like[]
  purchases TrackPurchase[]
}

model TrackPurchase {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  pointsPaid Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model Like {
  id            String    @id @default(cuid())
  userId        String
  trackId       String
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  track         Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  trackId   String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

enum TrackType {
  SONG
  BEAT
  LOOP
  DRUMKIT
}