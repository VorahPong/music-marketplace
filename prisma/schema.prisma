generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  handle            String    @unique
  email             String    @unique
  passwordHash      String
  role              UserRole  @default(CUSTOMER)
  emailVerifiedAt   DateTime?
  twoFactorEnabled  Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tracks            Track[]
  sessions          Session[]
  authCodes         AuthCode[]
  comments          Comment[]
  likes             Like[]
  purchases         TrackPurchase[]
}

model Track {
  id            String    @id @default(cuid())
  title         String
  description   String?
  previewMp3Url     String
  previewFileType   String?
  regularWavKey     String?
  fullZipKey        String?
  trackType         TrackType @default(SONG)
  bpm               Int?
  timeSignature     String?
  musicalKey        String?
  isForSale         Boolean   @default(false)
  regularPriceCents Int?
  fullPriceCents    Int?
  isPublished       Boolean   @default(true)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  ownerId       String?
  owner         User?     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  comments      Comment[]
  likes         Like[]
  purchases     TrackPurchase[]

  @@index([title])
  @@index([isPublished])
  @@index([deletedAt])
}

model TrackPurchase {
  id              String          @id @default(cuid())
  userId          String
  trackId         String
  version         PurchaseVersion @default(REGULAR)
  amountCents     Int
  receiptNumber   String?         @unique
  paypalOrderId   String?
  paypalCaptureId String?
  licenseType     LicenseType     @default(STANDARD)
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           Track           @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId, version])
  @@index([receiptNumber])
  @@index([paypalOrderId])
  @@index([paypalCaptureId])
  @@index([createdAt])
}

model Like {
  id            String    @id @default(cuid())
  userId        String
  trackId       String
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  track         Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthCode {
  id        String          @id @default(cuid())
  userId    String
  codeHash  String
  purpose   AuthCodePurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@index([expiresAt])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  trackId   String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

enum TrackType {
  SONG
  BEAT
  LOOP
  DRUMKIT
}

enum UserRole {
  CUSTOMER
  SELLER
}

enum AuthCodePurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum PurchaseVersion {
  REGULAR
  FULL
}

enum LicenseType {
  STANDARD
  CUSTOM
}